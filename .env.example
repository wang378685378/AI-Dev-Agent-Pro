# ==========================================
# AI Dev Agent Pro - 环境变量配置示例
# ==========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ==========================================

# ===== 必填项 =====

# API Key（必填）
# OpenAI: sk-...
# Azure: 你的 Azure key
# Ollama: 任意值（如 ollama）
# LM Studio: 任意值（如 lm-studio）
OPENAI_API_KEY=your_api_key_here

# ===== 可选项（自定义 API 供应商） =====

# 自定义 API 地址（留空使用默认 OpenAI API）
# OpenAI 默认: 留空
# Azure: https://your-resource.openai.azure.com/openai/deployments/your-deployment
# Ollama: http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
# Together AI: https://api.together.xyz/v1
# Anyscale: https://api.endpoints.anyscale.com/v1
OPENAI_BASE_URL=

# 模型名称
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Azure: 你的 deployment 名称
# Ollama: qwen2.5-coder:7b, codellama:13b 等
# LM Studio: 模型标识符
MODEL_NAME=gpt-4

# ===== 高级配置（可选） =====

# 生成温度（0.0-2.0，越低越稳定）
TEMPERATURE=0.2

# LLM 调用重试次数
MAX_RETRIES=3

# LLM 请求超时时间（秒）
TIMEOUT=60

# 最大代码修复尝试次数
MAX_FIX_ATTEMPTS=3
